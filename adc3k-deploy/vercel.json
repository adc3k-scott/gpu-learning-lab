{
  "version": 2,
  "buildCommand": null,
  "outputDirectory": ".",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data:; frame-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self' https://formsubmit.co;" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/card", "destination": "/card.html" },
    { "source": "/qr", "destination": "/qr.html" },
    { "source": "/factory", "destination": "/floor-plan.html" },
    { "source": "/factory-sim", "destination": "/production-sim.html" },
    { "source": "/study", "destination": "/study.html" },
    { "source": "/quiz", "destination": "/quiz.html" },
    { "source": "/cheatsheet", "destination": "/cheatsheet.html" },
    { "source": "/ncp-study", "destination": "/ncp-study.html" },
    { "source": "/ncp-cheat", "destination": "/ncp-cheat.html" },
    { "source": "/hub", "destination": "/hub.html" },
    { "source": "/gtc", "destination": "/gtc-plan.html" },
    { "source": "/stack", "destination": "/stack.html" },
    { "source": "/boot", "destination": "/boot.html" },
    { "source": "/investor", "destination": "/investor.html" },
    { "source": "/lafayette", "destination": "/lafayette.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
